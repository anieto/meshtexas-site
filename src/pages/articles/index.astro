---
import Layout from '../../components/Layout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const categoryLabels: Record<string, string> = {
  'how-to': 'How-To',
  buildout: 'Buildout / Infrastructure',
  community: 'Community',
  announcement: 'Announcement',
};
---
<Layout
  title="Articles — MeshTexas"
  description="How-to guides, buildout updates, and community news from MeshTexas."
>
  <div class="page-intro">
    <div class="container-narrow">
      <h1>Articles</h1>
      <p class="hero-sub">How-to guides, buildout updates, and community news from the MeshTexas network.</p>
    </div>
  </div>

  <section class="about-section">
    <div class="container-narrow">
      {articles.length === 0 && (
        <p class="hint">No articles published yet — check back soon.</p>
      )}
      <div class="article-list">
        {articles.map((article) => (
          <a href={`/articles/${article.id}/`} class="article-card">
            {article.data.thumbnail && (
              <img src={article.data.thumbnail} alt="" class="article-card-thumbnail" />
            )}
            <div class="article-card-meta">
              <span class="article-card-category">{categoryLabels[article.data.category]}</span>
              <span class="article-card-date">
                {article.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
              </span>
            </div>
            <h2>{article.data.title}</h2>
            <p>{article.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
